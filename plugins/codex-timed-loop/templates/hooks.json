{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "command": "python3 \"${CODEX_HOME:-$HOME/.codex}/codex-timed-loop/hooks/loop_stop.py\"",
            "statusMessage": "Evaluating the codex loop",
            "timeout": 30,
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "python3 \"${CODEX_HOME:-$HOME/.codex}/codex-timed-loop/hooks/loop_user_prompt_submit.py\"",
            "statusMessage": "Preparing the codex loop",
            "timeout": 30,
            "type": "command"
          }
        ]
      }
    ]
  }
}
